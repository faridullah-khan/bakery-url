{
  "name": "macaron-bakers",
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "images/*.{jpg,png,jpeg,gif}",
      "use": "@vercel/static"
    },
    {
      "src": "menu/*.{jpg,png,jpeg,gif}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}